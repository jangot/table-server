CHROME_PATH=/usr/bin/google-chrome
CHROME_USER_DATA_DIR=/path/to/chrome-data
CHROME_WINDOW_MODE=app
CHROME_WINDOW_WIDTH=1920
CHROME_WINDOW_HEIGHT=1080
CHROME_WINDOW_POSITION_X=0
CHROME_WINDOW_POSITION_Y=0
CHROME_DEVICE_SCALE_FACTOR=1
# CHROME_KIOSK=true
# CHROME_OZONE_PLATFORM=wayland

OBS_PATH=/usr/bin/obs
OBS_HOST=localhost
OBS_PORT=4455
OBS_PASSWORD=changeme
OBS_PROJECTOR_MONITOR_NAME=HDMI-A-3
OBS_PROJECTOR_SCENE_NAME=main
OBS_OUTPUT_SCENE_NAME=output.proector
# OBS_PROFILE_PATH=/home/user/.config/obs-studio

IDLE_PORT=3000
IDLE_VIEWS_PATH=./views
LOG_LEVEL=info

TELEGRAM_BOT_TOKEN=your-telegram-token
ALLOWED_TELEGRAM_USERS=your-telegram-username

# Optional configuration
SCENES_CONFIG_PATH=./config/scenes.json
DEVTOOLS_PORT=9222
CHROME_READY_TIMEOUT=30000
OBS_READY_TIMEOUT=10000
WATCHDOG_CHECK_INTERVAL_MS=10000
WATCHDOG_RESTART_MIN_INTERVAL_MS=60000
LAST_URL_STATE_PATH=.last-url
CHROME_SCRIPTS_DIR=./chrome-scripts
CHROME_SCRIPTS_MAP=./chrome-scripts-map.json

# Required
CHROME_PATH=/usr/bin/google-chrome
OBS_PATH=/usr/bin/obs
OBS_HOST=localhost
OBS_PORT=4455
OBS_PASSWORD=              # Tools → WebSocket Server Settings в OBS
TELEGRAM_BOT_TOKEN=        # токен от @BotFather
ALLOWED_TELEGRAM_USERS=    # comma-separated: user_id или username
IDLE_PORT=3000
IDLE_VIEWS_PATH=./views
LOG_LEVEL=info

# Optional
# DEVTOOLS_PORT=9222
# CHROME_READY_TIMEOUT=30000
# OBS_READY_TIMEOUT=10000
# OBS_PROJECTOR_MONITOR_NAME=DisplayPort-3  # системное имя монитора из xrandr (см. scripts/show-monitors.sh)
# CHROME_WINDOW_MODE=default    # kiosk | app | fullscreen | default
# CHROME_KIOSK=false            # true/1 — включить kiosk независимо от windowMode
# CHROME_OZONE_PLATFORM=        # x11 | wayland — явный выбор дисплейного сервера (Wayland-хосты)
# CHROME_USER_DATA_DIR=/tmp/chrome-profile
# CHROME_WINDOW_WIDTH=1280
# CHROME_WINDOW_HEIGHT=720
# CHROME_WINDOW_POSITION_X=0
# CHROME_WINDOW_POSITION_Y=0
# CHROME_DEVICE_SCALE_FACTOR=1  # По умолчанию 1 в kiosk/fullscreen; задайте явно для HiDPI (например, 2)
# WATCHDOG_CHECK_INTERVAL_MS=15000
# WATCHDOG_RESTART_MIN_INTERVAL_MS=10000
