# Required
CHROME_PATH=/usr/bin/google-chrome
OBS_PATH=/usr/bin/obs
IDLE_PORT=3000
IDLE_VIEWS_PATH=./views
LOG_LEVEL=info

# Optional
# DEVTOOLS_PORT=9222
# CHROME_READY_TIMEOUT=30000
# OBS_READY_TIMEOUT=10000
# CHROME_WINDOW_MODE=default
# CHROME_USER_DATA_DIR=/tmp/chrome-profile
# CHROME_WINDOW_WIDTH=1280
# CHROME_WINDOW_HEIGHT=720
# CHROME_WINDOW_POSITION_X=0
# CHROME_WINDOW_POSITION_Y=0
# CHROME_DEVICE_SCALE_FACTOR=1
# WATCHDOG_CHECK_INTERVAL_MS=15000
# WATCHDOG_RESTART_MIN_INTERVAL_MS=10000
